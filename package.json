{
  "name": "odoo-kiosk",
  "version": "1.0.0-beta.12",
  "description": "adoo IoT",
  "license": "MIT",
  "author": {
    "name": "andyengit",
    "email": "andyengit@users.noreply.github.com"
  },
  "maintainer": "andyengit <andyengit@users.noreply.github.com>",
  "desktopName": "adoo-iot",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "changelog:sync": "node scripts/sync-changelog.js",
    "changelog:preview": "node scripts/release-notes.js",
    "release:github": "bash scripts/github-release.sh",
    "rebuild": "node scripts/patch-usb-binding.js && electron-rebuild -f -w serialport,usb",
    "postinstall": "node scripts/postinstall.js",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:validate:mac": "bash scripts/collect-release-artifacts.sh mac",
    "dist:validate:linux": "bash scripts/collect-release-artifacts.sh linux",
    "dist:validate:win": "bash scripts/collect-release-artifacts.sh win"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "http_ece": "^1.2.0",
    "serialport": "^13.0.0",
    "usb": "^2.18.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "happy-dom": "^17.6.3",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.andyengit.odoo-kiosk",
    "productName": "adoo IoT",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "poweredbyandy",
      "repo": "adoo-live"
    },
    "artifactName": "adoo-IoT-${version}-${arch}.${ext}",
    "icon": "icon.png",
    "files": [
      "main.js",
      "config.default.json",
      "icon.png",
      "src/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "artifactName": "adoo-IoT-Setup-${version}.${ext}",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "portable": {
      "artifactName": "adoo-IoT-${version}-portable.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "maintainer": "andyengit <andyengit@users.noreply.github.com>",
      "syncDesktopName": true
    }
  }
}
